# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
ENVIRONMENT=development
LOG_LEVEL=debug

# Database
DATABASE_URL=postgres://flex:flex_password@localhost:5432/flex_db?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=300

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-32-chars-min
JWT_REFRESH_SECRET=change-me-refresh-secret-32-chars-min
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=flex-api

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@flex.bj

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Mobile Money (MTN MoMo API)
MTN_MOMO_API_KEY=your-mtn-momo-key
MTN_MOMO_API_SECRET=your-mtn-momo-secret
MTN_MOMO_ENVIRONMENT=sandbox
